backend/Secrets.json
backend/.env

# ==========================================
# 4. Database (SQLite / Local DBs)
# ==========================================
# Ignore local runtime databases if they auto-generate on startup
# Remove the lines below if you explicitly want to commit a template SQLite file
database/*.db
database/*.db-wal
database/*.db-shm
*.sqlite